# Git RAG MCP Pipeline Configuration
# Copy to pipeline.yaml and customize.

# Chunking settings
chunk:
  chunk_size: 512       # tokens per chunk
  overlap: 64           # overlap in tokens
  strategy: fixed       # fixed | semantic

# Embedding model
embedder:
  provider: sentence_transformers   # sentence_transformers | openai
  model_name: all-MiniLM-L6-v2     # or text-embedding-3-small for OpenAI
  batch_size: 64

# Vector store
store:
  backend: qdrant       # qdrant | faiss
  persist_dir: ./data/qdrant
  qdrant_collection: git_rag

# Where to clone repos
repos_dir: ./data/repos

# Agent swarm for bootstrap documentation generation
agents:
  orchestrator:
    provider: openai              # openai | transformers
    model_name: gpt-4o            # Strong model for synthesis
    # api_key: sk-...             # Or set GIT_RAG_ORCHESTRATOR_API_KEY
    # base_url: https://...       # For Anthropic or other OpenAI-compatible APIs
    max_tokens: 4096
    temperature: 0.2
    context_window: 128000
  sub_agent:
    provider: openai
    model_name: gpt-4o-mini       # Fast/cheap model for exploration
    # api_key: sk-...             # Or set GIT_RAG_SUB_AGENT_API_KEY
    # base_url: https://...
    max_tokens: 4096
    temperature: 0.2
    context_window: 128000
  context_budget_fraction: 0.25   # Max fraction of context window for source material
  max_concurrent_agents: 4
  max_followup_rounds: 2
