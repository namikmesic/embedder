# vectordb-mcp — Configuration
# Copy to pipeline.yaml and customize.

# Embedding model
embedder:
  provider: sentence_transformers   # sentence_transformers | openai
  model: BAAI/bge-base-en-v1.5       # or text-embedding-3-small for OpenAI
  batch_size: 64

# Vector store (PostgreSQL + pgvector)
store:
  pg_dsn: postgresql://postgres:postgres@localhost:5432/vectordb
  table_name: chunks
  ef_search: 40            # HNSW exploration factor. Higher = better recall, slower.
  iterative_scan: false     # pgvector 0.8+ iterative scan for filtered queries.
  hybrid_alpha: 1.0         # 1.0 = pure vector, <1.0 blends in BM25 keyword scoring.
  pool_min_size: 1          # asyncpg connection pool minimum size.
  pool_max_size: 10         # asyncpg connection pool maximum size.
